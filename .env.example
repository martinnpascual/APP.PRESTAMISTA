# --- Supabase (Backend ONLY — nunca en variables VITE_) ---
SUPABASE_URL=https://obyfkrprseobehfxusdi.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<obtener en: Dashboard → Settings → API → service_role key>

# JWT secret para verificación local (más rápido, opcional)
# Obtener en: Dashboard → Settings → API → JWT Settings → "JWT Secret"
