# backend/.env.example — Copiar a backend/.env y completar valores reales.
# NUNCA commitear el archivo .env con valores reales.

# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://obyfkrprseobehfxusdi.supabase.co
SUPABASE_SERVICE_ROLE_KEY=COMPLETAR_Dashboard_Settings_API_service_role
SUPABASE_JWT_SECRET=COMPLETAR_Dashboard_Settings_API_JWT_Secret

# ── App ─────────────────────────────────────────────────────────────────────
DEBUG=false
# En desarrollo: ["http://localhost:5173"]
# En producción: ["https://tu-app.vercel.app"]
CORS_ORIGINS=["http://localhost:5173"]

# ── Scheduler ───────────────────────────────────────────────────────────────
# Zona horaria para los jobs nocturnos (no cambiar salvo relocalización)
# TZ=America/Argentina/Buenos_Aires   # ya está hardcodeado en el scheduler

# ── Telegram Bot (solo al prestamista) ──────────────────────────────────────
# Crear bot: @BotFather → /newbot
# Chat ID: escribirle a @userinfobot o usar getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Email SMTP ──────────────────────────────────────────────────────────────
# Gmail: usar App Password (no contraseña normal)
# Activar en: myaccount.google.com → Seguridad → Contraseñas de aplicaciones
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── n8n Webhook (opcional) ──────────────────────────────────────────────────
# Si no está configurado, el sistema usa Telegram directo como fallback
N8N_WEBHOOK_URL=

# ── Deploy ──────────────────────────────────────────────────────────────────
# Para Railway — sobreescribir workers según CPU disponibles
UVICORN_WORKERS=2
LOG_LEVEL=info
